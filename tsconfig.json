{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["@webgpu/types", "node"],
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./src",
    "paths": {
      "*.wgsl": ["./shaders/*.wgsl"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/*-backup.ts", "src/*-new.ts"]
}